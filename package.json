{
  "name": "erp-product-management",
  "private": true,
  "scripts": {
    "dev:backend": "cd backend && mvn -q -DskipTests spring-boot:run -Dspring-boot.run.profiles=dev",
    "dev:frontend": "cd frontend && npm run dev",
