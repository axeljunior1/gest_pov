{
  "name": "erp-product-management",
  "private": true,
  "scripts": {
    "dev": "powershell -ExecutionPolicy Bypass -File ./dev.ps1",
    "stop": "powershell -ExecutionPolicy Bypass -File ./dev.ps1 -StopOnly",
    "db": "powershell -ExecutionPolicy Bypass -File ./db.ps1",
    "db:stop": "powershell -ExecutionPolicy Bypass -File ./db.ps1 -Stop",
    "backend": "cd backend && mvn -q -DskipTests spring-boot:run",
    "frontend": "cd frontend && npm run dev"
  }
}
