# =============================================================================
# Gest_POV — variables Docker (copier vers .env avant déploiement compose)
# cp .env.example .env
# =============================================================================

# PostgreSQL (service db)
POSTGRES_DB=erp_products
POSTGRES_USER=erp_user
POSTGRES_PASSWORD=change-me-strong-password

# Spring Boot (service backend) — hôte = nom du service Docker "db"
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/erp_products
SPRING_DATASOURCE_USERNAME=erp_user
SPRING_DATASOURCE_PASSWORD=change-me-strong-password

# JWT production (min. 32 caractères)
APP_JWT_SECRET=change-me-jwt-secret-min-256-bits-long-key!!

# Ports exposés sur la machine hôte (optionnel)
FRONTEND_PORT=80
BACKEND_PORT=8080
